{
	"info": {
		"_postman_id": "a89fb089-a38a-4c58-ae01-c025ebf0cc40",
		"name": "Automation of aircraft on a postman",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
